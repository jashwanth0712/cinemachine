{
  "expo": {
    "name": "Cinemachine",
    "slug": "cinemachine",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/cinemachine_logo.jpg",
    "userInterfaceStyle": "light",
    "scheme": "cinemachine",
    "splash": {
      "image": "./assets/cinemachine_logo.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8F0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cinemachine.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Cinemachine needs camera access to record your amazing movies!",
        "NSMicrophoneUsageDescription": "Cinemachine needs microphone access so you can talk to your AI director buddy!"
      }
    },
    "android": {
      "package": "com.cinemachine.app",
      "adaptiveIcon": {
        "backgroundColor": "#FFF8F0",
        "foregroundImage": "./assets/cinemachine_logo.jpg",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/cinemachine_logo.jpg"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/cinemachine_logo.jpg",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Cinemachine needs camera access to record your amazing movies!",
          "microphonePermission": "Cinemachine needs microphone access so you can talk to your AI director buddy!"
        }
      ],
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "Cinemachine needs microphone access so you can talk to your AI director buddy!"
        }
      ]
    ]
  }
}
